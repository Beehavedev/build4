generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String     @id @default(cuid())
  telegramId         BigInt     @unique
  username           String?
  referredBy         String?
  referralCode       String     @unique @default(cuid())
  subscriptionTier   String     @default("free")
  subscriptionExpiry DateTime?
  totalFeesSpent     Float      @default(0)
  createdAt          DateTime   @default(now())

  wallets       Wallet[]
  agents        Agent[]
  trades        Trade[]
  quests        UserQuest[]
  copyFollowing CopyFollow[] @relation("follower")
  copyCopied    CopyFollow[] @relation("copied")
  portfolio     Portfolio?
}

model Wallet {
  id          String   @id @default(cuid())
  userId      String
  chain       String
  address     String
  encryptedPK String
  label       String   @default("Wallet 1")
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Agent {
  id              String    @id @default(cuid())
  userId          String
  name            String
  description     String?
  isActive        Boolean   @default(false)
  isPaused        Boolean   @default(false)
  exchange        String    @default("aster")
  pairs           String[]  @default(["BTC/USDT"])
  timeframe       String    @default("15m")
  maxPositionSize Float     @default(100)
  maxDailyLoss    Float     @default(50)
  maxLeverage     Float     @default(5)
  stopLossPct     Float     @default(2)
  takeProfitPct   Float     @default(4)
  memorySnapshot  Json?
  totalPnl        Float     @default(0)
  totalTrades     Int       @default(0)
  winRate         Float     @default(0)
  isListed        Boolean   @default(false)
  listingPrice    Float?
  subscriberCount Int       @default(0)
  createdAt       DateTime  @default(now())
  lastTickAt      DateTime?

  user     User          @relation(fields: [userId], references: [id])
  trades   Trade[]
  memories AgentMemory[]
}

model AgentMemory {
  id        String   @id @default(cuid())
  agentId   String
  type      String
  content   String
  embedding Float[]
  metadata  Json?
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id])
}

model Trade {
  id         String    @id @default(cuid())
  userId     String
  agentId    String?
  exchange   String
  pair       String
  side       String
  entryPrice Float
  exitPrice  Float?
  size       Float
  leverage   Float     @default(1)
  pnl        Float?
  pnlPct     Float?
  status     String    @default("open")
  txHash     String?
  aiReasoning String?
  signalsUsed Json?
  openedAt   DateTime  @default(now())
  closedAt   DateTime?

  user  User   @relation(fields: [userId], references: [id])
  agent Agent? @relation(fields: [agentId], references: [id])
}

model CopyFollow {
  id         String   @id @default(cuid())
  followerId String
  copiedId   String
  allocation Float    @default(100)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  follower User @relation("follower", fields: [followerId], references: [id])
  copied   User @relation("copied", fields: [copiedId], references: [id])
}

model Portfolio {
  id              String   @id @default(cuid())
  userId          String   @unique
  totalValue      Float    @default(0)
  totalPnl        Float    @default(0)
  totalPnlPct     Float    @default(0)
  dayPnl          Float    @default(0)
  verifiedOnChain Boolean  @default(false)
  lastUpdated     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Quest {
  id          String      @id @default(cuid())
  title       String
  description String
  reward      Float
  type        String
  requirement Json
  isActive    Boolean     @default(true)

  userQuests UserQuest[]
}

model UserQuest {
  id        String    @id @default(cuid())
  userId    String
  questId   String
  progress  Int       @default(0)
  completed Boolean   @default(false)
  claimedAt DateTime?

  user  User  @relation(fields: [userId], references: [id])
  quest Quest @relation(fields: [questId], references: [id])
}
