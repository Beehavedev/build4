generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  telegramId        BigInt    @unique
  username          String?
  firstName         String?
  referredBy        String?
  referralCode      String    @unique @default(cuid())
  subscriptionTier  String    @default("free")
  subscriptionExpiry DateTime?
  totalFeesSpent    Float     @default(0)
  b4Balance         Float     @default(0)
  // ── Linked external wallet for $B4 holder verification ──────────────────
  // Set when a user proves ownership of an EOA via signMessage on
  // /api/me/link-wallet. The on-chain $B4 balance at link time (and on
  // refresh) is cached in linkedB4Balance. Airdrop allocations are
  // computed against linkedB4WalletAddress, NOT the bot-managed wallet —
  // we want to reward the holder wallet, not force users to move tokens.
  linkedB4WalletAddress  String?
  linkedB4Balance        Float?
  linkedB4At             DateTime?
  // Aster exchange credentials (per-user, encrypted)
  asterApiKey       String?
  asterApiSecret    String?
  asterAgentAddress String?   // agent/signer address approved for this user
  asterOnboarded    Boolean   @default(false)
  // ── Hyperliquid (added 2026-04-23) ────────────────────────────────────────
  // Same wallet address as Aster (BSC wallet works on HL since both are EVM
  // and use the same secp256k1 derivation). Agent is a separate keypair the
  // user authorises via approveAgent so server-side trades don't need master.
  hyperliquidAgentAddress     String?
  hyperliquidAgentEncryptedPK String?
  hyperliquidOnboarded        Boolean @default(false)
  // ── Per-venue agent-trading allow flags (added 2026-04-27) ───────────────
  // User-controlled "my agents are allowed to place trades on this venue".
  // Independent from onboarded flags (which mean "user has connected the
  // venue") — a user can be onboarded on Hyperliquid but choose to pause
  // all HL agent activity without disconnecting. Default true so existing
  // users keep their current behaviour after the migration.
  asterAgentTradingEnabled       Boolean @default(true)
  hyperliquidAgentTradingEnabled Boolean @default(true)
  // Phase 4 (2026-05-01) — per-user pause flag for Polymarket. Mirrors
  // the aster/HL pattern so the "ALLOWED TRADING PLATFORMS" toggle in
  // Agent Studio has a 4th, fully-functional row. Default true so
  // existing users opt-in by default; the per-agent gate (Safe deployed
  // + USDC funded, enforced inside polymarketAgent.ts) means turning
  // this on for un-onboarded users is harmless.
  polymarketAgentTradingEnabled  Boolean @default(true)
  pinHash           String?   // PBKDF2 hash of user's wallet PIN (optional security layer)
  pinSalt           String?
  // 42.space prediction-market live trading opt-in. Default true — all
  // 42.space trades execute on-chain on BSC. Legacy paper positions still
  // settle as paper (the executor reads each row's stored paperTrade
  // flag), but no new paper trades are created. Field retained as an
  // admin-only emergency kill-switch; user-facing toggles removed.
  fortyTwoLiveTrade Boolean   @default(true)
  // Telegram delivery health flag — set true when the Bot API returns
  // 403 Forbidden for this user (user blocked the bot or deleted the
  // chat). Used to skip them in broadcasts and avoid wasted retries.
  // Live in DB on 17k+ rows; do NOT drop without a migration plan.
  botBlocked        Boolean   @default(false)
  // Multi-provider swarm decision-making opt-in. Default false → single-provider
  // (Anthropic). When true, the trading agent runs the prompt across every
  // configured provider and uses the quorum verdict. See src/swarm/swarm.ts.
  swarmEnabled      Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt

  wallets           Wallet[]
  agents            Agent[]
  trades            Trade[]
  userQuests        UserQuest[]
  copyFollowing     CopyFollow[] @relation("follower")
  copyCopied        CopyFollow[] @relation("copied")
  portfolio         Portfolio?
  agentLogs         AgentLog[]
}

// Internal migration tracker — manually appended one-shot data fixups
// (e.g. backfills) record their name + appliedAt here. Schema-managed
// by hand, not by `prisma migrate`. Listed here so `prisma db push`
// doesn't try to drop the table on every sync.
model DataMigration {
  name      String   @id
  appliedAt DateTime @default(now())

  @@map("_DataMigration")
}

model Wallet {
  id           String   @id @default(cuid())
  userId       String
  chain        String
  address      String
  encryptedPK  String
  label        String   @default("Wallet 1")
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// (ERC-8004 fields appended below in Agent model)
model Agent {
  id              String    @id @default(cuid())
  userId          String
  name            String
  description     String?
  isActive        Boolean   @default(false)
  isPaused        Boolean   @default(false)

  exchange        String    @default("mock")
  // Per-agent venue allow-list. Each tick the runner enumerates this list
  // and dispatches a *separate* scan + decision + execute pass per venue —
  // i.e. an agent enabled for both Aster and HL gets two independent ticks
  // (HL's orderbook → HL decision → HL fill, Aster's orderbook → Aster
  // decision → Aster fill). Empty array = agent is implicitly inactive
  // even if isActive=true. `exchange` above is retained as the legacy
  // "primary venue" used for wallet/onchain identity routing; operational
  // dispatch reads enabledVenues. Backfilled at boot to [exchange] for
  // existing rows so behaviour is unchanged until users opt in to the
  // new per-agent venue chips.
  enabledVenues   String[]  @default([])
  pairs           String[]  @default(["BTC/USDT"])
  timeframe       String    @default("15m")
  maxPositionSize Float     @default(100)
  maxDailyLoss    Float     @default(50)
  maxLeverage     Float     @default(5)
  stopLossPct     Float     @default(2)
  takeProfitPct   Float     @default(4)

  memorySnapshot  Json?
  totalPnl        Float     @default(0)
  totalTrades     Int       @default(0)
  winRate         Float     @default(0)

  isListed        Boolean   @default(false)
  listingPrice    Float?
  subscriberCount Int       @default(0)

  // On-chain identity — every BUILD4 agent lives in its own wallet
  walletAddress   String?   @unique
  encryptedPK     String?
  onchainTxHash   String?
  onchainChain    String?   @default("BSC")

  // ERC-8004 Trustless AI Agents Standard fields
  learningModel    String?
  learningRoot     String?
  metadataUri      String?
  identityStandard String?  @default("ERC-8004")

  // ERC-8004 IdentityRegistry — mandatory on-chain registration (BSC)
  erc8004AgentId   String?
  erc8004TxHash    String?
  erc8004FundTxHash String?
  erc8004Verified  Boolean  @default(false)

  // BAP-578 NFA NFT — optional 0.015 BNB upgrade via the official registry
  bap578TokenId    String?
  bap578TxHash     String?
  bap578Verified   Boolean  @default(false)

  // AUTO-mode scanner state — set after each tick when pairs:['AUTO']
  currentPair      String?
  lastScanScore    Int?

  // Polymarket Phase 3 — autonomous prediction-market trading.
  // When true the polymarketAgent runner picks this agent up on its tick,
  // scans top events, and places EOA-signed orders against the Polymarket
  // CLOB (with our builderCode attached for grant attribution).
  polymarketEnabled Boolean  @default(false)
  // Per-trade USDC budget the agent may commit to a single Polymarket
  // position. Capped at maxPositionSize so users have one mental model.
  polymarketMaxSizeUsdc Float @default(5)
  // Conviction floor (0..1) — agent only trades when the LLM swarm's
  // probability estimate diverges from market-implied price by at least
  // this much. 0.10 = 10pp edge.
  polymarketEdgeThreshold Float @default(0.10)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  lastTickAt      DateTime?
  lastPolymarketTickAt DateTime?

  user            User      @relation(fields: [userId], references: [id])
  trades          Trade[]
  memories        AgentMemory[]
  logs            AgentLog[]

  @@index([userId])
  @@index([isActive])
}

model AgentMemory {
  id        String   @id @default(cuid())
  agentId   String
  type      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  agent     Agent    @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([type])
}

model Trade {
  id          String    @id @default(cuid())
  userId      String
  agentId     String?

  exchange    String
  pair        String
  side        String
  entryPrice  Float
  exitPrice   Float?
  size        Float
  leverage    Float     @default(1)
  pnl         Float?
  pnlPct      Float?

  status      String    @default("open")
  txHash      String?

  aiReasoning String?
  signalsUsed Json?

  openedAt    DateTime  @default(now())
  closedAt    DateTime?

  user        User      @relation(fields: [userId], references: [id])
  agent       Agent?    @relation(fields: [agentId], references: [id])

  @@index([userId])
  @@index([agentId])
  @@index([status])
}

model CopyFollow {
  id          String   @id @default(cuid())
  followerId  String
  copiedId    String
  allocation  Float    @default(100)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  follower    User     @relation("follower", fields: [followerId], references: [id])
  copied      User     @relation("copied", fields: [copiedId], references: [id])

  @@unique([followerId, copiedId])
}

model Portfolio {
  id              String   @id @default(cuid())
  userId          String   @unique
  totalValue      Float    @default(0)
  totalPnl        Float    @default(0)
  totalPnlPct     Float    @default(0)
  dayPnl          Float    @default(0)
  verifiedOnChain Boolean  @default(false)
  lastUpdated     DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
}

model Quest {
  id          String      @id @default(cuid())
  title       String
  description String
  reward      Float
  type        String
  requirement Json
  isActive    Boolean     @default(true)

  userQuests  UserQuest[]
}

model UserQuest {
  id        String    @id @default(cuid())
  userId    String
  questId   String
  progress  Int       @default(0)
  completed Boolean   @default(false)
  claimedAt DateTime?

  user      User      @relation(fields: [userId], references: [id])
  quest     Quest     @relation(fields: [questId], references: [id])

  @@unique([userId, questId])
}

// 42.space prediction-market positions opened by trading agents.
// Mirrors Trade in spirit: one row per outcome-token position; status moves
// open → closed (manually flipped by agent) or open → resolved (settled by
// the on-chain resolution sweep).
/// On-chain outcome-token holdings on 42.space prediction markets.
model OutcomePosition {
  id              String    @id @default(cuid())
  userId          String
  agentId         String?

  marketAddress   String    // 42.space market contract on BSC
  marketTitle     String    // human-readable question
  tokenId         Int       // ERC-1155 outcome token id (= 2^index)
  outcomeLabel    String

  // Sizing
  usdtIn          Float     // collateral committed (USDT)
  entryPrice      Float     // implied probability at entry (0..1)
  exitPrice       Float?    // implied prob at close OR 1 if winning resolution
  payoutUsdt      Float?    // USDT received on close/resolution
  pnl             Float?    // payoutUsdt - usdtIn

  // Real outcome-token amount received at open (read from chain in live mode).
  // Null in paper-trade mode → callers fall back to usdtIn / entryPrice.
  outcomeTokenAmount Float?

  status          String    @default("open") // open | closed | resolved_win | resolved_loss
  paperTrade      Boolean   @default(true)   // false = real on-chain tx fired
  txHashOpen      String?
  txHashClose     String?
  reasoning       String?
  // Per-provider swarm telemetry captured at open. Shape:
  // [{ provider, model, action, predictionTrade?, reasoning, latencyMs, inputTokens, outputTokens, tokensUsed }]
  // (inputTokens/outputTokens added in Task #24; older rows only carry tokensUsed.)
  // Null on positions opened by the legacy single-provider path.
  providers       Json?

  openedAt        DateTime  @default(now())
  closedAt        DateTime?

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@index([marketAddress])
}

// Editable per-provider cost rates used by getSwarmStats to estimate USD spend
// from raw token counts. Defaults live in code (DEFAULT_COST_USD_PER_MTOKENS)
// and can be overridden via the SWARM_COST_USD_PER_MTOKENS env var; rows in
// this table take precedence over both so ops can adjust pricing from the
// admin UI without a redeploy.
model ProviderCostRate {
  provider         String   @id
  usdPer1MTokens   Float
  updatedAt        DateTime @default(now()) @updatedAt
  updatedBy        String?  // telegramId of admin who last edited
}

model AgentLog {
  id              String   @id @default(cuid())
  agentId         String
  userId          String
  action          String
  rawResponse     String?
  parsedAction    String?
  executionResult String?
  error           String?
  pair            String?
  price           Float?
  reason          String?
  adx             Float?
  rsi             Float?
  score           Int?
  regime          String?
  // Which venue this log entry belongs to ('aster' | 'hyperliquid' |
  // 'fortytwo' | 'polymarket'). The runner expands each agent into per-venue tick
  // units and overrides `agent.exchange` on a CLONE per tick — so the
  // Agent table's `exchange` column does NOT reflect which venue was
  // actually being scanned when an HL or 42 tick wrote a log row. This
  // column captures the per-tick venue at write time so the brain feed
  // can render the correct chip (HL / Aster / 42). Null on legacy rows
  // written before this column existed (the feed falls back to
  // agent.exchange in that case).
  exchange        String?
  // Per-provider swarm telemetry captured at decision time. Shape:
  // [{ provider, model, action, predictionTrade?, reasoning, latencyMs, inputTokens, outputTokens, tokensUsed }]
  // (inputTokens/outputTokens added in Task #24; older rows only carry tokensUsed.)
  // Null when the user is on the single-provider path.
  providers       Json?
  createdAt       DateTime @default(now())

  agent           Agent    @relation(fields: [agentId], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  @@index([agentId])
  @@index([userId, createdAt])
}

// =====================================================================
// Polymarket — Phase 2 (manual trading) + Phase 3 (autonomous AI agent).
// EOA-signed orders against the Polygon CTF Exchange via the official
// CLOB REST API. Builder code attached to every order for grant-eligible
// volume attribution under the Polymarket Builder Program.
// =====================================================================

// Per-user Polymarket L2 API credentials (HMAC key/secret/passphrase),
// derived once from the custodial PK and persisted encrypted so we don't
// have to re-derive on every tick. allowanceTxHash records the one-time
// USDC->CTF Exchange approval — once present we know the user can place
// orders without an on-chain pre-step.
model PolymarketCreds {
  id                  String   @id @default(cuid())
  userId              String   @unique
  walletAddress       String   // Polygon EOA — signs orders. Same key as BSC.
  // Gnosis Safe proxy deployed by Polymarket's relayer. Holds USDC.e and
  // ERC-1155 outcome shares. CLOB orders are signed by walletAddress but
  // the funder field references safeAddress, and the exchange pulls
  // collateral from the Safe — not the EOA. Populated on first /setup.
  safeAddress         String?
  safeDeployedAt      DateTime?
  apiKey              String
  encryptedApiSecret  String
  encryptedPassphrase String
  // Last relayer transactionHash for the USDC + CTF approval batch.
  // Distinct from a regular Polygon tx hash but serves the same purpose
  // here — proof we ran the one-time approve flow successfully.
  allowanceTxHash     String?
  allowanceVerifiedAt DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now()) @updatedAt

  @@index([walletAddress])
  @@index([safeAddress])
}

// One row per Polymarket order BUILD4 places on the user's behalf
// (manual via Phase 2 UI or autonomous via Phase 3 agent). status mirrors
// the CLOB order lifecycle plus our own resolution states.
model PolymarketPosition {
  id              String    @id @default(cuid())
  userId          String
  agentId         String?

  conditionId     String    // hex condition id from Gamma
  tokenId         String    // ERC-1155 outcome token id (decimal string, big)
  marketSlug      String?
  marketTitle     String
  outcomeLabel    String    // 'Yes' | 'No' | other
  side            String    // 'BUY' | 'SELL'

  // Sizing
  sizeUsdc        Float     // notional USDC committed at order time
  entryPrice      Float     // implied probability at fill (0..1)
  fillSize        Float?    // outcome tokens filled (sizeUsdc / entryPrice if fully filled)
  exitPrice       Float?
  payoutUsdc      Float?
  pnl             Float?

  // CLOB lifecycle
  orderHash       String?   // EIP-712 hash returned by CLOB
  orderId         String?   // CLOB order id
  status          String    @default("placed") // placed | matched | filled | cancelled | failed | resolved_win | resolved_loss
  errorMessage    String?

  // Attribution
  builderCode     String?   // bytes32 attached at order time

  // LLM swarm telemetry (Phase 3 agent path)
  reasoning       String?
  providers       Json?

  openedAt        DateTime  @default(now())
  closedAt        DateTime?

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@index([conditionId])
}
