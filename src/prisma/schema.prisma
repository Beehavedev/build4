generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  telegramId        BigInt    @unique
  username          String?
  firstName         String?
  referredBy        String?
  referralCode      String    @unique @default(cuid())
  subscriptionTier  String    @default("free")
  subscriptionExpiry DateTime?
  totalFeesSpent    Float     @default(0)
  b4Balance         Float     @default(0)
  // Aster exchange credentials (per-user, encrypted)
  asterApiKey       String?
  asterApiSecret    String?
  asterAgentAddress    String?   // agent/signer address approved for this user (UNIQUE per user)
  asterAgentEncryptedPK String?  // AES-encrypted private key for above agent (server-side trade signing)
  asterOnboarded    Boolean   @default(false)
  // ── Hyperliquid (added 2026-04-23) ────────────────────────────────────────
  // Same wallet address as the user's BSC wallet (HL is EVM, addresses derive
  // from the same secp256k1 PK). Agent is a separate keypair the user
  // authorises via approveAgent so the server can sign orders without holding
  // the master PK in memory. Mirrors the asterAgent* pattern above.
  hyperliquidAgentAddress     String?
  hyperliquidAgentEncryptedPK String?
  hyperliquidOnboarded        Boolean @default(false)
  pinHash           String?   // PBKDF2 hash of user's wallet PIN (optional security layer)
  pinSalt           String?
  // Multi-provider swarm decision-making opt-in (Task #18). Default false →
  // single-provider Anthropic. When true, every trading tick is run across
  // all configured providers and the quorum verdict wins.
  swarmEnabled      Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt

  wallets           Wallet[]
  agents            Agent[]
  trades            Trade[]
  userQuests        UserQuest[]
  copyFollowing     CopyFollow[] @relation("follower")
  copyCopied        CopyFollow[] @relation("copied")
  portfolio         Portfolio?
  agentLogs         AgentLog[]
}

model Wallet {
  id           String   @id @default(cuid())
  userId       String
  chain        String
  address      String
  encryptedPK  String
  label        String   @default("Wallet 1")
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// (ERC-8004 fields appended below in Agent model)
model Agent {
  id              String    @id @default(cuid())
  userId          String
  name            String
  description     String?
  isActive        Boolean   @default(false)
  isPaused        Boolean   @default(false)

  exchange        String    @default("mock")
  pairs           String[]  @default(["BTC/USDT"])
  timeframe       String    @default("15m")
  maxPositionSize Float     @default(100)
  maxDailyLoss    Float     @default(50)
  maxLeverage     Float     @default(5)
  stopLossPct     Float     @default(2)
  takeProfitPct   Float     @default(4)

  memorySnapshot  Json?
  totalPnl        Float     @default(0)
  totalTrades     Int       @default(0)
  winRate         Float     @default(0)

  isListed        Boolean   @default(false)
  listingPrice    Float?
  subscriberCount Int       @default(0)

  // On-chain identity — every BUILD4 agent lives in its own wallet
  walletAddress   String?   @unique
  encryptedPK     String?
  onchainTxHash   String?
  onchainChain    String?   @default("BSC")

  // ERC-8004 Trustless AI Agents Standard fields
  learningModel    String?
  learningRoot     String?
  metadataUri      String?
  identityStandard String?  @default("ERC-8004")

  // ERC-8004 IdentityRegistry — mandatory on-chain registration (BSC)
  erc8004AgentId   String?
  erc8004TxHash    String?
  erc8004FundTxHash String?
  erc8004Verified  Boolean  @default(false)

  // BAP-578 NFA NFT — optional 0.015 BNB upgrade via the official registry
  bap578TokenId    String?
  bap578TxHash     String?
  bap578Verified   Boolean  @default(false)

  // AUTO-mode scanner state — set after each tick when pairs:['AUTO']
  currentPair      String?
  lastScanScore    Int?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  lastTickAt      DateTime?

  user            User      @relation(fields: [userId], references: [id])
  trades          Trade[]
  memories        AgentMemory[]
  logs            AgentLog[]

  @@index([userId])
  @@index([isActive])
}

model AgentMemory {
  id        String   @id @default(cuid())
  agentId   String
  type      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  agent     Agent    @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([type])
}

model Trade {
  id          String    @id @default(cuid())
  userId      String
  agentId     String?

  exchange    String
  pair        String
  side        String
  entryPrice  Float
  exitPrice   Float?
  size        Float
  leverage    Float     @default(1)
  pnl         Float?
  pnlPct      Float?

  status      String    @default("open")
  txHash      String?

  aiReasoning String?
  signalsUsed Json?

  openedAt    DateTime  @default(now())
  closedAt    DateTime?

  user        User      @relation(fields: [userId], references: [id])
  agent       Agent?    @relation(fields: [agentId], references: [id])

  @@index([userId])
  @@index([agentId])
  @@index([status])
}

model CopyFollow {
  id          String   @id @default(cuid())
  followerId  String
  copiedId    String
  allocation  Float    @default(100)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  follower    User     @relation("follower", fields: [followerId], references: [id])
  copied      User     @relation("copied", fields: [copiedId], references: [id])

  @@unique([followerId, copiedId])
}

model Portfolio {
  id              String   @id @default(cuid())
  userId          String   @unique
  totalValue      Float    @default(0)
  totalPnl        Float    @default(0)
  totalPnlPct     Float    @default(0)
  dayPnl          Float    @default(0)
  verifiedOnChain Boolean  @default(false)
  lastUpdated     DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
}

model Quest {
  id          String      @id @default(cuid())
  title       String
  description String
  reward      Float
  type        String
  requirement Json
  isActive    Boolean     @default(true)

  userQuests  UserQuest[]
}

model UserQuest {
  id        String    @id @default(cuid())
  userId    String
  questId   String
  progress  Int       @default(0)
  completed Boolean   @default(false)
  claimedAt DateTime?

  user      User      @relation(fields: [userId], references: [id])
  quest     Quest     @relation(fields: [questId], references: [id])

  @@unique([userId, questId])
}

model AgentLog {
  id              String   @id @default(cuid())
  agentId         String
  userId          String
  action          String
  rawResponse     String?
  parsedAction    String?
  executionResult String?
  error           String?
  pair            String?
  price           Float?
  reason          String?
  adx             Float?
  rsi             Float?
  score           Int?
  regime          String?
  // Per-tick swarm telemetry (Task #18). Shape per element:
  // { provider, model, action, predictionTrade?, reasoning, latencyMs, inputTokens, outputTokens, tokensUsed }
  // (inputTokens/outputTokens added in Task #24; older rows only carry tokensUsed.)
  // Null when the user is on the single-provider path.
  providers       Json?
  createdAt       DateTime @default(now())

  agent           Agent    @relation(fields: [agentId], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  @@index([agentId])
  @@index([userId, createdAt])
}

// 42.space prediction-market positions held by users (live + paper).
// CRITICAL: must stay defined here so `prisma db push --accept-data-loss`
// (in render.yaml buildCommand) does NOT drop the table on every deploy.
// We had a months-long bug where this model only existed in the legacy
// /prisma/schema.prisma and the buildCommand uses /src/prisma/schema.prisma,
// so each Render deploy treated the live OutcomePosition table as
// "extra" and silently dropped it — wiping every live & paper position.
model OutcomePosition {
  id              String    @id @default(cuid())
  userId          String
  agentId         String?

  marketAddress   String
  marketTitle     String
  tokenId         Int
  outcomeLabel    String

  usdtIn          Float
  entryPrice      Float
  exitPrice       Float?
  payoutUsdt      Float?
  pnl             Float?

  // Real outcome-token amount received at open (read from chain in live mode).
  // Null in paper-trade mode → callers fall back to usdtIn / entryPrice.
  outcomeTokenAmount Float?

  status          String    @default("open") // open | closed | resolved_win | resolved_loss
  paperTrade      Boolean   @default(true)
  txHashOpen      String?
  txHashClose     String?
  reasoning       String?
  // Per-provider swarm telemetry captured at open (see ProviderCostRate).
  providers       Json?

  openedAt        DateTime  @default(now())
  closedAt        DateTime?

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@index([marketAddress])
}
