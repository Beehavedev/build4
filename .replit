modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5904
externalPort = 3000

[env]
PORT = "5000"

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "npx tsx src/server.ts"]
build = ["bash", "-c", "npx prisma generate --schema=src/prisma/schema.prisma && npx vite build --config src/miniapp/vite.config.ts src/miniapp"]
publicDir = "dist/public"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx src/server.ts"
waitForPort = 5000

[[workflows.workflow]]
name = "test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run test"

[workflows.workflow.metadata]
isValidation = true

[userenv]

[userenv.shared]
ONCHAIN_NETWORK = "bnbMainnet"
AGENT_RUNNER_ENABLED = "true"
BAP578_CONTRACT_ADDRESS = "0xd7Deb29ddBB13607375Ce50405A574AC2f7d978d"
TELEGRAM_BOT_EXTERNAL = "true"
ASTER_PROXY_URL = "https://build4-1.onrender.com"

[agent]
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
